{ "tools":[
  {
    "name": "ea_me",
    "description": "Return the authenticated user (id, email, roles), the list of tenants they can access, and the connection-default tenant. Use to confirm identity and enumerate available tenants.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "response_format": {
          "type": "string",
          "enum": ["json", "markdown"],
          "default": "markdown",
          "description": "Either 'json' (machine-parseable) or 'markdown' (human-readable). Default 'markdown'."
        }
      }
    }
  },
  {
    "name": "ea_get_current_user",
    "description": "Returns the current authenticated user's profile and organizations. Organizations are loaded from the EA entity system, not from JWT claims.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "response_format": {
          "type": "string",
          "enum": ["json", "markdown"],
          "default": "markdown"
        }
      }
    }
  },
  {
    "name": "ea_get_oidc_discovery",
