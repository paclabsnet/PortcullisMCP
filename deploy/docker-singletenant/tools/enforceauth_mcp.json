    "inputSchema": {
      "type": "object",
      "properties": {
        "response_format": {
          "type": "string",
          "enum": ["json", "markdown"],
          "default": "markdown"
        }
      }
    }
  },
  {
    "name": "ea_list_my_tenants",
    "description": "List the tenants the authenticated user can access. Returns tenant id, name, and is_connection_default flag. Use when tenant slug is needed for tenant-scoped tools.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "response_format": {
          "type": "string",
          "enum": ["json", "markdown"],
          "default": "markdown"
        }
      }
    }
  },
  {
