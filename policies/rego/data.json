		},
                "fetch" : {
                        "fetch_url": {
                                "allow" : {
                                        "groups" : ["*"]
                                },
                                "escalate" : {
                                        "arg_restrictions" :[
                                              { "type":"regex", "key_path":"resource.arguments.host", "data":"(?i)^[a-z0-9.-]+\\.styra\\.com$"},
                                              { "type":"prefix","key_path":"resource.arguments.host", "data":"www.STyRa.CoM"},
                                              { "type":"prefix","key_path":"resource.arguments.host", "data":"www.OpenPolicyAgent.org"},
                                              { "type":"prefix","key_path":"resource.arguments.host", "data":"OpenPolicyAgent.org"}
                                        ]
                                }
                        },
                        "fetch" : {
                                "allow" : {
                                        "groups" : ["*"]
                                },
                                "deny" : {
                                        "arg_restrictions" :[
                                                { "type":"and", "list" :[
                                                        { "type":"prefix", "key_path": "resource.arguments.host", "data": "competitor.com" },
                                                        { "type":"prefix", "key_path": "resource.arguments.path", "data": "/v1/jobs" }
                                                   ]
                                                }
                                        ]
                                },
                                "escalate" : {
                                        "arg_restrictions" :[
                                                { "type":"and", "list" :[
