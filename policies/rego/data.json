                                              { "type":"gte","key_path":"resource.arguments.gte_val", "data":20},
                                              { "type":"lt","key_path":"resource.arguments.lt_val", "data":30},
                                              { "type":"lte","key_path":"resource.arguments.lte_val", "data":40},
