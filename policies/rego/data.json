				"allow" : {
					"groups" : [ "admin", "developer", "clerk" ]
				}
			},
                        "update_customer": {
				"allow" : {
					"groups" : [ "admin" ]
				}, 
                                "escalate": {
                                        "arg_restrictions" :[
						{ "type":"prefix","key_path":"resource.arguments.customer_id", "data":"" },
                                                { "type":"gte","key_path":"resource.arguments.customer_id", "data":0 }
                                        ]
                                }
                        },
			"query_order": {
				"allow" : {
