                                                        { "type":"prefix", "key_path": "resource.arguments.path", "data": "/v1/products" }
                                                   ]
                                                }, 
                                                { "type":"prefix","key_path":"resource.arguments.host", "data":"STyRa.CoM"},
                                                { "type":"regex","key_path":"resource.arguments.host", "data":"(?i)^[a-z0-9.-]+\\.styra\\.com$"},
                                                { "type":"prefix","key_path":"resource.arguments.host", "data":"OpenPolicyAgent.com"}
                                        ]
                                }
                        }
                }, 
