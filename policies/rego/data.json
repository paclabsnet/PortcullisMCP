{
        "config" : {
		"escalation_secret" : "a-string-secret-at-least-256-bits-long"
        },
  "portcullis": {
	"mcp" : {

		"portcullis-localfs": {

			"read_file" : {
				"allow" : {
					"groups" : [ "*" ]
				}
			},
			"read_text_file" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                }
			},
                        "read_media_file" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                },
                                "deny" : {
                                        "arg_restrictions" :[
                                                { "type":"suffix", "key_path": "resource.arguments.path.filename.extension", "data": ".gz" }
                                        ]
                                }

                        },
                        "read_multiple_files" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                }

                        },
                        "write_file" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                },
                                "escalate" : {
                                        "arg_restrictions" :[
                                                { "type":"prefix", "key_path": "resource.arguments.path", "data": "C:\\Program Files" },
                                                { "type":"prefix", "key_path": "resource.arguments.path", "data": "C:\\Users\\Public" },
                                                { "type":"prefix", "key_path": "resource.arguments.path", "data": "C:\\Program Files (x86)" },
                                                { "type":"prefix", "key_path": "resource.arguments.path", "data": "/var" }
                                        ]
                                },
                                "deny" : {
                                        "arg_restrictions" :[
                                                { "type":"prefix", "key_path": "resource.arguments.path", "data": "C:\\Windows" },
                                                { "type":"prefix", "key_path": "resource.arguments.path", "data": "C:\\ProgramData" },
                                                { "type":"prefix", "key_path": "resource.arguments.path", "data": "/boot" },
                                                { "type":"prefix", "key_path": "resource.arguments.path", "data": "/proc" },
                                                { "type":"prefix", "key_path": "resource.arguments.path", "data": "/sys" },
                                                { "type":"prefix", "key_path": "resource.arguments.path", "data": "/etc" },
                                                { "type":"prefix", "key_path": "resource.arguments.path", "data": "/lib" },
                                                { "type":"prefix", "key_path": "resource.arguments.path", "data": "~/.ssh" },
                                                { "type":"prefix", "key_path": "resource.arguments.path", "data": "~/.gnupg" }
