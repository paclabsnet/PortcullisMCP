{
        "config" : {
		"escalation_secret" : "a-string-secret-at-least-256-bits-long"
        },
  "portcullis": {
	"mcp" : {

		"portcullis-localfs": {

			"read_file" : {
				"allow" : {
					"groups" : [ "*" ]
				}
			},
			"read_text_file" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                }
			},
                        "read_media_file" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                },
                                "deny" : {
                                        "arg_restrictions" :[
                                                { "type":"suffix", "key_path": "path.filename.extension", "data": ".gz" }
                                        ]
                                }

                        },
                        "read_multiple_files" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                }

                        },
                        "write_file" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                },
                                "escalate" : {
                                        "arg_restrictions" :[
                                                { "type":"prefix", "key_path": "path", "data": "C:\\Program Files" },
                                                { "type":"prefix", "key_path": "path", "data": "C:\\Users\\Public" },
                                                { "type":"prefix", "key_path": "path", "data": "C:\\Program Files (x86)" },
                                                { "type":"prefix", "key_path": "path", "data": "/var" }
                                        ]
                                },
                                "deny" : {
                                        "arg_restrictions" :[
                                                { "type":"prefix", "key_path": "path", "data": "C:\\Windows" },
                                                { "type":"prefix", "key_path": "path", "data": "C:\\ProgramData" },
                                                { "type":"prefix", "key_path": "path", "data": "/boot" },
                                                { "type":"prefix", "key_path": "path", "data": "/proc" },
                                                { "type":"prefix", "key_path": "path", "data": "/sys" },
                                                { "type":"prefix", "key_path": "path", "data": "/etc" },
                                                { "type":"prefix", "key_path": "path", "data": "/lib" },
                                                { "type":"prefix", "key_path": "path", "data": "~/.ssh" },
                                                { "type":"prefix", "key_path": "path", "data": "~/.gnupg" }
                                        ]
                                }

                        },
                        "edit_file" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                }

                        },
                        "create_directory" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                }

                        },
                        "list_directory" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                }

                        },
                        "list_directory_with_sizes" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                }

                        },
                        "directory_tree" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                }

                        },
                        "move_file" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                }

                        },
                        "search_files" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                }

                        },
                        "copy_file" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                }

                        },
                        "delete_file" : {
                                "allow" : {
                                        "groups" : [ "admin" ]
                                }

                        },
                        "search_within_files" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                }

                        },
                        "get_file_info" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                }

                        },
                        "list_allowed_directories" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                }

                        }


		},
		"mock-enterprise-api": {

			"get_customer": {
				"allow" : {
					"groups" : [ "admin", "developer", "clerk" ]
				}
			},
                        "update_customer": {
				"allow" : {
					"groups" : [ "admin" ]
				}, 
                                "escalate": {
                                        "arg_restrictions" :[
						{ "type":"prefix","key_path":"customer_id", "data":"" },
                                                { "type":"gte","key_path":"customer_id", "data":0 }
                                        ]
                                }
                        },
			"query_order": {
				"allow" : {
					"groups" : [ "*" ]
				}
			},
			"update_order_status": {
				"allow" : {
					"groups" : [ "admin" ]
				}
			},
			"query_inventory": {
				"allow" : {
					"groups" : [ "*" ]
				}
			},
			"delete_order": {
				"allow" : {
					"groups" : [ "admin" ]
				}
			}

		},
                "fetch" : {
                        "fetch_url": {
                                "allow" : {
                                        "groups" : ["*"]
                                },
                                "escalate" : {
                                        "arg_restrictions" :[
                                              { "type":"regex", "key_path":"host", "data":"(?i)^[a-z0-9.-]+\\.styra\\.com$"},
                                              { "type":"prefix","key_path":"host", "data":"www.STyRa.CoM"},
                                              { "type":"prefix","key_path":"host", "data":"www.OpenPolicyAgent.org"},
                                              { "type":"prefix","key_path":"host", "data":"OpenPolicyAgent.org"}
                                        ]
                                }
                        },
                        "fetch" : {
                                "allow" : {
                                        "groups" : ["*"]
                                },
                                "deny" : {
                                        "arg_restrictions" :[
                                                { "type":"and", "list" :[
                                                        { "type":"prefix", "key_path": "host", "data": "competitor.com" },
                                                        { "type":"prefix", "key_path": "path", "data": "/v1/jobs" }
                                                   ]
                                                }
                                        ]
                                },
                                "escalate" : {
                                        "arg_restrictions" :[
                                                { "type":"and", "list" :[
                                                        { "type":"PREFIX", "key_path": "host", "data": "competitor.com" },
                                                        { "type":"prefix", "key_path": "path", "data": "/v1/products" }
                                                   ]
                                                }, 
                                                { "type":"prefix","key_path":"host", "data":"STyRa.CoM"},
                                                { "type":"regex","key_path":"host", "data":"(?i)^[a-z0-9.-]+\\.styra\\.com$"},
                                                { "type":"prefix","key_path":"host", "data":"OpenPolicyAgent.com"}
                                        ]
                                }
                        }
                }, 
                "mock-calculator" : {
                        "calculate" : {
                                "allow" : {
                                        "arg_restrictions" :[
                                              { "type":"equals","key_path":"equal_val", "data":1000},
                                              { "type":"gt","key_path":"gt_val", "data":10},
                                              { "type":"gte","key_path":"gte_val", "data":20},
                                              { "type":"lt","key_path":"lt_val", "data":30},
                                              { "type":"lte","key_path":"lte_val", "data":40},
                                              { "type":"within_range","key_path":"range_val", "data":[50,60]},
                                              { "type":"outside_range","key_path":"range_val", "data":[0,2000]}
                                        ]
                                }
                        }
                }

	}
  }
