              "tool_name": "update_order_status"
            },
            "resource":{
                "arguments": {
                  "order_id":"ABC123",
                  "status":"SHIPPED"
                }
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["developer", "blah"]
            },
            "context": {
              "escalation_tokens":[
                {"raw":"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..5jM9MCU4c6aQOXuQGG8o32S_X1pd1cnN4XrzoPxzEnM"}
              ]
            }
          },
          "session_id": "tbd123",
          "trace_id": "req-abc123"
        }



####################################################
#
# fetch
  - name: fetch - returns allow
    skip: false
    description:  validating a URL fetch request to a valid URL
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"allow"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {                
            "action": {
                "tool_name": "fetch",
                "service" : "fetch"
            },
            "resource": {
                "arguments": {
                    "raw": "https://internal-api.example.com/v1/customers",
                    "scheme": "https",
                    "host": "internal-api.example.com",
                    "port": "",
                    "path": "/v1/customers",
                    "query": ""
                }
            },
            "principal": {
                "user_id": "alice@example.com",
                "email": "alice@example.com",
                "display_name": "Alice Developer",
                "groups": ["developer", "internal-api-users"],
                "roles": ["api-consumer"],
                "department": "engineering",
                "auth_method": ["pwd", "mfa"],
                "token_expiry": 1741651200,
                "source_type": "oidc"
            },
            "context": {
                "escalation_tokens": []
            }
          },
            "session_id": "sess-abc123",
            "trace_id": "req-def456"
        }
    

  - name: fetch - returns deny
    skip: false
    description:  validating a URL fetch request to an inappropriate URL
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"deny"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {                
            "action": {
                "tool_name": "fetch",
                "service" : "fetch"
            },
            "resource": {
                "arguments": {
                    "raw": "https://competitor.com/v1/jobs",
                    "scheme": "https",
                    "host": "competitor.com",
                    "port": "",
                    "path": "/v1/jobs",
                    "query": ""
                }
            },
            "principal": {
                "user_id": "alice@example.com",
                "email": "alice@example.com",
                "display_name": "Alice Developer",
                "groups": ["developer", "internal-api-users"],
                "roles": ["api-consumer"],
                "department": "engineering",
                "auth_method": ["pwd", "mfa"],
                "token_expiry": 1741651200,
                "source_type": "oidc"
            },
            "context": {
                "escalation_tokens": []
            }
          },
            "session_id": "sess-abc123",
            "trace_id": "req-def456"
        }


#
# source of the JWT 
#
# {
#  "portcullis": {
#    "tools":       ["fetch"],
#    "services":    ["fetch"],
#    "groups" :     ["developer"],
#    "arg_restrictions": [
#       { "type":"prefix", "key_path": "host", "data": "competitor.com", "required":true },
#       { "type":"prefix", "key_path": "path", "data": "/v1/products", "required":true }       
#    ]
#  }
# }
  - name: fetch - returns escalate
    skip: false
    description:  validating a URL fetch request to a sketchy URL that requires escalation
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"escalate"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {                
            "action": {
                "tool_name": "fetch",
                "service" : "fetch"
            },
            "resource": {
                "arguments": {
                    "raw": "https://competitor.com/v1/products",
                    "scheme": "https",
                    "host": "competitor.com",
                    "port": "",
                    "path": "/v1/products",
                    "query": ""
                }
            },
            "principal": {
                "user_id": "alice@example.com",
                "email": "alice@example.com",
                "display_name": "Alice Developer",
                "groups": ["developer", "internal-api-users"],
                "roles": ["api-consumer"],
                "department": "engineering",
                "auth_method": ["pwd", "mfa"],
                "token_expiry": 1741651200,
                "source_type": "oidc"
            },
            "context": {
                "escalation_tokens": [
                    {"raw":"BAD_TOKEN"}                    
                ]
            }
          },
            "session_id": "sess-abc123",
            "trace_id": "req-def456"
        }








  - name: fetch - returns escalate - no token provided
    skip: false
