#
#  escalation scenarios




  - name: returns escalate appropriately for write_file 
    description: checking arguments against escalation criteria
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"escalate"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action": {
              "service": "portcullis-localfs",
              "tool_name": "write_file"
            },
            "resource":{
              "arguments": {
                "path": "/var/log/whatever.log"
              }
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["developers", "blah"]
            },
            "context": {
              "escalation_tokens":[

              ]
            }
          },
          "session_id": "tbd123",
          "trace_id": "req-abc123"
        }










#########################################################
#
#  mock-enterprise-api
#
#  additional test scenarios that we want to exercise
#
#  these are failing, because the semantics of the escalate are
#  different than they were for the filesystem.
#
#  in the filesystem, allow is inferior to escalate - if the
#  escalate response is included in the list, it is preferred
#  over the allow response.  
#
#  In this case, if the user is in the appropriate group, the
#  allow matters, not the escalate. We're just working on 
#  groups, we're not worried about arguments. 
#
#  need to ponder this, this is a little tricky
#
#


  - name: mock-enterprise-api - get_customer - returns allow 
    skip: false
    description: the user is in an allowed group
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"allow"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action":{
              "service": "mock-enterprise-api",
              "tool_name": "get_customer"
            },
            "resource":{
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["developer", "blah"]
            },
            "context": {
              "escalation_tokens":[
              ]
            }
          },
          "session_id": "tbd123",
          "trace_id": "req-abc123"
        }







  - name: mock-enterprise-api - delete_order - returns allow if you're an admin
    skip: false
    description: the user is an admin
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"allow"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action":{
              "service": "mock-enterprise-api",
              "tool_name": "delete_order"
            },
            "resource":{
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["developer", "admin"]
            },
            "context": {
              "escalation_tokens":[
              ]
            }
          },
          "session_id": "tbd123",
          "trace_id": "req-abc123"
        }


  - name: mock-enterprise-api - delete_order - returns deny if you're not an admin
    skip: false
    description: the user is not an admin
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"deny"'
    input:
