#####################################################################
#
#  escalation scenarios




  - name: returns escalate appropriately for write_file 
    description: checking arguments against escalation criteria
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"escalate"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action": {
              "service": "portcullis-localfs",
              "tool_name": "write_file"
            },
            "resource":{
              "arguments": {
                "path": "/var/log/whatever.log"
              }
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["developers", "blah"]
            },
            "context": {
              "escalation_tokens":[

              ]
            }
          },
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }




#
# the token for returns allow after escalation
# secret: a-string-secret-at-least-256-bits-long
#
# {
#  "sub": "1234567890",
#  "name": "John Doe",
#  "admin": true,
#  "iat": 1516239022,
#  "portcullis": {
#    "tools":       ["write_file", "edit_file"],
#    "services":    ["portcullis-localfs"],
#    "groups" :     ["developer"],
#    "arg_restrictions": [
#       { "type":"prefix", "key_path": "path", "data": "/var/log/whatever.log", "required":true }
#    ],
#    "reason":      "Allow writing to /var/log"
#     
#  }
# }
#
#
  - name: returns allow after escalation
    description: checking that the escalation token provides the appropriate override
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"allow"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action": {
              "service": "portcullis-localfs",
              "tool_name": "write_file"
            },
            "resource":{
              "arguments": {
                "path": "/var/log/whatever.log"
              }
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["developers", "blah"]
            },
            "context": {
              "escalation_tokens":[
                  { "raw":"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..hPTYnOWOIy5andqOWhUJCQNumLwL22ypHwhG5Xd8bUg" }
              ]
            }
          },
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }







#########################################################
#
#  mock-enterprise-api
#
#  additional test scenarios that we want to exercise
#
#  these are failing, because the semantics of the escalate are
#  different than they were for the filesystem.
#
#  in the filesystem, allow is inferior to escalate - if the
#  escalate response is included in the list, it is preferred
#  over the allow response.  
#
#  In this case, if the user is in the appropriate group, the
#  allow matters, not the escalate. We're just working on 
#  groups, we're not worried about arguments. 
#
#  need to ponder this, this is a little tricky
#
#


  - name: mock-enterprise-api - get_customer - returns allow 
    skip: false
    description: the user is in an allowed group
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"allow"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action":{
              "service": "mock-enterprise-api",
              "tool_name": "get_customer"
            },
            "resource":{
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["developer", "blah"]
            },
            "context": {
              "escalation_tokens":[
              ]
            }
          },
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }


#
# {
#  "portcullis": {
#    "tools":       ["get_customer", "update_inventory"],
#    "services":    ["mock-enterprise-api"],
#    "groups" :     ["blah"],
#    "arg_restrictions": [
#    ],
#    "reason":      "update group membership"     
#  }
#}
#

  - name: mock-enterprise-api - get_customer - returns escalate 
    skip: false
    description: the escalation token(s) don't provide the necessary privilege
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"escalate"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action":{
              "service": "mock-enterprise-api",
              "tool_name": "get_customer"
            },
            "resource":{
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["blah"]
            },
            "context": {
              "escalation_tokens":[
                  { "raw":"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..hPTYnOWOIy5andqOWhUJCQNumLwL22ypHwhG5Xd8bUg" }
              ]
            }
          },
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }



# {
#  "portcullis": {
#    "tools":       ["get_customer", "update_inventory"],
#    "services":    ["mock-enterprise-api"],
#    "groups" :     ["developer"],
#    "arg_restrictions": [
#    ],
#    "reason":      "update group membership"     
#  }
# }
#
  - name: mock-enterprise-api - get_customer - returns allow after escalation
    skip: false
    description: checking that the escalation token provides the appropriate override
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"allow"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action": {
