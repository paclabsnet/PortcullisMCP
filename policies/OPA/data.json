                                "allow" : {
                                        "groups" : [ "*" ]
                                }

                        },
                        "move_file" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                }

                        },
                        "search_files" : {
                                "allow" : {
                                        "groups" : [ "*" ]
                                }

                        },
