              }
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["developers", "blah"]
            },
            "context": {
              "escalation_tokens":[

              ]
            }
          },
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }



  - name: can't write to /boot
    description: checking arguments
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"deny"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action": {
              "service": "portcullis-localfs",
              "tool_name": "write_file"
            },
            "resource":{
              "arguments": {
                "path": "/boot/image"
              }
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["developers", "blah"]
            },
            "context": {
              "escalation_tokens":[
              ]
            }
          },
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }





  - name: no deny for a .tar etxension
    description: checking that the traverse_json function works properly
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"allow"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action": {
              "service": "portcullis-localfs",
              "tool_name": "read_media_file"
            },
            "resource":{
              "arguments": {
                "path": { 
                    "directory":"/var/log/whatever",
                    "extension":".tar"
                }
              }
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["developers", "blah"]
            },
            "context": {
              "escalation_tokens":[
              ]
            }
          },
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }



  - name: denies for a .gz extension
    description: checking that the traverse_json function works properly
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"deny"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action": {
              "service": "portcullis-localfs",
              "tool_name": "read_media_file"
            },
            "resource":{
              "arguments": {
                "path": { 
                    "directory":"/var/log/whatever",
                    "filename": {
                        "body":"test",
                        "extension":".gz"
                    }
                }
              }
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["developers", "blah"]
            },
            "context": {
              "escalation_tokens":[
              ]
            }
          },
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }



#####################################################################
#
#  escalation scenarios




  - name: returns escalate appropriately
    description: checking arguments against escalation criteria
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"escalate"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action": {
              "service": "portcullis-localfs",
              "tool_name": "write_file"
            },
            "resource":{
              "arguments": {
                "path": "/var/log/whatever.log"
              }
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["developers", "blah"]
            },
            "context": {
              "escalation_tokens":[

              ]
            }
          },
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }




#
# the token for returns allow after escalation
# secret: a-string-secret-at-least-256-bits-long
#
# {
#  "sub": "1234567890",
#  "name": "John Doe",
#  "admin": true,
#  "iat": 1516239022,
#  "portcullis": {
#    "tools":       ["write_file", "edit_file"],
#    "services":    ["portcullis-localfs"],
#    "groups" :     ["developer"],
#    "arg_restrictions": [
#       { "type":"prefix", "key_path": "path", "data": "/var/log/whatever.log", "required":true }
#    ],
#    "reason":      "Allow writing to /var/log"
#     
#  }
# }
#
#
  - name: returns allow after escalation
    description: checking that the escalation token provides the appropriate override
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"allow"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action": {
              "service": "portcullis-localfs",
              "tool_name": "write_file"
            },
            "resource":{
              "arguments": {
                "path": "/var/log/whatever.log"
              }
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["developers", "blah"]
            },
            "context": {
              "escalation_tokens":[
                  { "raw":"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..hPTYnOWOIy5andqOWhUJCQNumLwL22ypHwhG5Xd8bUg" }
              ]
            }
          },
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }


