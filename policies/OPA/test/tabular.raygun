suite: verify the functionality of the tabular decision matrix
description: we'll send a variety of inputs to simulate various requests from an AI agent wishing to use a MCP
opa:
  bundle-path: ../bundle.tar.gz 

tests:
  - name: anyone can read a file
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"allow"'
    input:
      type: inline
      value: >
        {
          "service": "portcullis-localfs",
          "tool_name": "read_file",
          "arguments": {
            "path": "/workspace/src/main.go"
          },
          "user_identity": {
            "user_id": "alice@example.com",
            "display_name": "Alice Developer",
            "groups": ["developers", "team-backend"]
          },
          "escalation_tokens":[

          ],
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }

  - name: invalid inputs result in a deny
    description: invalid service
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"deny"'
    input:
      type: inline
      value: >
        {
          "service": "XXXXXXXX",
          "tool_name": "read_file",
          "arguments": {
            "path": "/workspace/src/main.go"
          },
          "user_identity": {
            "user_id": "alice@example.com",
            "display_name": "Alice Developer",
            "groups": ["developers", "team-backend"]
          },
          "escalation_tokens":[

          ],
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }

  - name: invalid inputs result in a deny
    description: missing service
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"deny"'
    input:
      type: inline
      value: >
        {
          "_service": "XXXXXXXX",
          "tool_name": "read_file",
          "arguments": {
            "path": "/workspace/src/main.go"
          },
          "user_identity": {
            "user_id": "alice@example.com",
            "display_name": "Alice Developer",
            "groups": ["developers", "team-backend"]
          },
          "escalation_tokens":[

          ],
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }


  - name: invalid inputs result in a deny
    description: missing tool_name
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"deny"'
    input:
      type: inline
      value: >
        {
          "service": "portcullis-localfs",
          "_tool_name": "read_file",
          "arguments": {
            "path": "/workspace/src/main.go"
          },
          "user_identity": {
            "user_id": "alice@example.com",
            "display_name": "Alice Developer",
            "groups": ["developers", "team-backend"]
          },
          "escalation_tokens":[

          ],
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }


  - name: invalid inputs result in a deny
    description: invalid tool_name
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"deny"'
    input:
      type: inline
      value: >
        {
          "service": "portcullis-localfs",
          "_tool_name": "compile_file",
          "arguments": {
            "path": "/workspace/src/main.go"
          },
          "user_identity": {
            "user_id": "alice@example.com",
            "display_name": "Alice Developer",
            "groups": ["developers", "team-backend"]
          },
          "escalation_tokens":[

          ],
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }


  - name: invalid inputs result in a deny
    skip: false
    description: missing user_identity
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"deny"'
    input:
      type: inline
      value: >
        {
          "service": "portcullis-localfs",
          "tool_name": "read_file",
          "arguments": {
            "path": "/workspace/src/main.go"
          },
          "_user_identity": {
            "user_id": "alice@example.com",
            "display_name": "Alice Developer",
            "groups": ["developers", "team-backend"]
          },
          "escalation_tokens":[

          ],
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }


  - name: invalid inputs result in a deny
    skip: false
    description: missing request_id
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"deny"'
    input:
      type: inline
      value: >
        {
          "service": "portcullis-localfs",
          "tool_name": "read_file",
          "arguments": {
            "path": "/workspace/src/main.go"
          },
          "user_identity": {
            "user_id": "alice@example.com",
            "display_name": "Alice Developer",
            "groups": ["developers", "team-backend"]
          },
          "escalation_tokens":[

          ],
          "session_id": "tbd123",
          "_request_id": "req-abc123"
        }


  - name: only admins can delete a file
    skip: false
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"allow"'
    input:
      type: inline
      value: >
        {
          "service": "portcullis-localfs",
          "tool_name": "delete_file",
          "arguments": {
            "path": "/workspace/src/main.go"
          },
          "user_identity": {
            "user_id": "alice@example.com",
            "display_name": "Alice Developer",
            "groups": ["developers", "admin"]
          },
          "escalation_tokens":[

          ],
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }


  - name: only admins can delete a file
    skip: false
    description: failure case
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"deny"'
    input:
      type: inline
      value: >
        {
          "service": "portcullis-localfs",
          "tool_name": "delete_file",
          "arguments": {
            "path": "/workspace/src/main.go"
          },
          "user_identity": {
            "user_id": "alice@example.com",
            "display_name": "Alice Developer",
            "groups": ["developers", "blah"]
          },
          "escalation_tokens":[

          ],
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }



  - name: can't write to /boot
    description: checking arguments
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"deny"'
    input:
      type: inline
      value: >
        {
          "service": "portcullis-localfs",
          "tool_name": "write_file",
          "arguments": {
            "path": "/boot/image"
          },
          "user_identity": {
            "user_id": "alice@example.com",
            "display_name": "Alice Developer",
            "groups": ["developers", "blah"]
          },
          "escalation_tokens":[

          ],
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }





  - name: no deny for a .tar etxension
    description: checking that the traverse_json function works properly
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"allow"'
    input:
      type: inline
      value: >
        {
          "service": "portcullis-localfs",
          "tool_name": "read_media_file",
          "arguments": {
            "path": { 
                "directory":"/var/log/whatever",
                "extension":".tar"
            }
          },
          "user_identity": {
            "user_id": "alice@example.com",
            "display_name": "Alice Developer",
            "groups": ["developers", "blah"]
          },
          "escalation_tokens":[
          ],
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }



  - name: denies for a .gz extension
    description: checking that the traverse_json function works properly
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"deny"'
    input:
      type: inline
      value: >
        {
          "service": "portcullis-localfs",
          "tool_name": "read_media_file",
          "arguments": {
            "path": { 
                "directory":"/var/log/whatever",
                "filename": {
                    "body":"test",
                    "extension":".gz"
                }
            }
          },
          "user_identity": {
            "user_id": "alice@example.com",
            "display_name": "Alice Developer",
            "groups": ["developers", "blah"]
          },
          "escalation_tokens":[
          ],
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }



#####################################################################
#
#  escalation scenarios


#
# the token for returns allow after escalation
# secret: a-string-secret-at-least-256-bits-long
#
# {
#  "sub": "1234567890",
#  "name": "John Doe",
#  "admin": true,
#  "iat": 1516239022,
#  "portcullis": {
#    "tools":       ["write_file", "edit_file"],
#    "services":    ["portcullis-localfs"],
#    "groups" :     ["developer"],
#    "arg_restrictions": [
#       { "type":"prefix", "key_path": "path", "data": "/var/log/whatever.log", "required":true }
#    ],
#    "reason":      "Allow writing to /var/log"
#     
#  }
# }
#
#
  - name: returns allow after escalation
    description: checking that the escalation token provides the appropriate override
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"allow"'
    input:
      type: inline
      value: >
        {
          "service": "portcullis-localfs",
          "tool_name": "write_file",
          "arguments": {
            "path": "/var/log/whatever.log"
          },
          "user_identity": {
            "user_id": "alice@example.com",
            "display_name": "Alice Developer",
            "groups": ["developers", "blah"]
          },
          "escalation_tokens":[
              { "raw":"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..hPTYnOWOIy5andqOWhUJCQNumLwL22ypHwhG5Xd8bUg" }
          ],
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }

