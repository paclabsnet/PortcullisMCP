        }


  - name: invalid inputs result in a deny
    skip: false
    description: missing user_identity
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"deny"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action": {
              "service": "portcullis-localfs",
              "tool_name": "read_file"
            },
            "resource":{
              "arguments": {
