        }


  - name: system handles a missing request_id gracefully
    skip: false
    description: missing request_id
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"allow"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action": {
              "service": "portcullis-localfs",
              "tool_name": "read_file"
            },
            "resource":{
              "arguments": {
                "path": "/workspace/src/main.go"
              }
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["developers", "team-backend"]
            },
            "context": {
              "escalation_tokens":[

              ]
            }
          },
          "session_id": "tbd123",
          "_request_id": "req-abc123"
        }


  - name: only admins can delete a file
    skip: false
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"allow"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action": {
              "service": "portcullis-localfs",
              "tool_name": "delete_file"
            },
            "resource":{
              "arguments": {
                "path": "/workspace/src/main.go"
              }
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["developers", "admin"]
            },
            "context": {
              "escalation_tokens":[

              ]
            }
          },
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }


  - name: only admins can delete a file
    skip: false
    description: failure case
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"deny"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action": {
              "service": "portcullis-localfs",
              "tool_name": "delete_file"
            },
            "resource":{
              "arguments": {
