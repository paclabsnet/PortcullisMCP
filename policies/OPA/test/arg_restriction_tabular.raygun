
suite: verify the functionality of the tabular decision matrix
description: we'll send a variety of inputs to simulate various requests from an AI agent wishing to use a MCP
opa:
  bundle-path: ../bundle.tar.gz 


tests:

#########################################################
#
#  mock-enterprise-api
#
#  additional test scenarios that we want to exercise
#
#  these are failing, because the semantics of the escalate are
#  different than they were for the filesystem.
#
#  in the filesystem, allow is inferior to escalate - if the
#  escalate response is included in the list, it is preferred
#  over the allow response.  
#
#  In this case, if the user is in the appropriate group, the
#  allow matters, not the escalate. We're just working on 
#  groups, we're not worried about arguments. 
#
#  need to ponder this, this is a little tricky
#
#


  - name: mock-enterprise-api - get_customer - returns allow 
    description: the user is in an allowed group
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"allow"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action":{
              "service": "mock-enterprise-api",
              "tool_name": "get_customer"
            },
            "resource":{
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["developers", "blah"]
            },
            "context": {
              "escalation_tokens":[
              ]
            }
          },
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }


  - name: mock-enterprise-api - get_customer - returns escalate 
    description: the escalation token(s) don't provide the necessary privilege
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"escalate"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action":{
              "service": "mock-enterprise-api",
              "tool_name": "get_customer"
            },
            "resource":{
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["blah"]
            },
            "context": {
              "escalation_tokens":[
                  { "raw":"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..hPTYnOWOIy5andqOWhUJCQNumLwL22ypHwhG5Xd8bUg" }
              ]
            }
          },
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }



  - name: mock-enterprise-api - get_customer - returns allow after escalation
    description: checking that the escalation token provides the appropriate override
    decision-path: /v1/data/portcullis/tabular/decision
    expects:
      - substring: '"decision":"allow"'
    input:
      type: inline
      value: >
        {
          "authorization_request": {
            "action": {
              "service": "mock-enterprise-api",
              "tool_name": "get_customer"
            },
            "resource":{
            },
            "principal": {
              "user_id": "alice@example.com",
              "display_name": "Alice Developer",
              "groups": ["blah"]
            },
            "context": {
              "escalation_tokens":[
                  { "raw":"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..eCCM5fYkMOuWB1aQbqqhrFAewb7jFoZxrezo_bJsQS0" }
              ]
            }
          },
          "session_id": "tbd123",
          "request_id": "req-abc123"
        }
